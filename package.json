{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.ts",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
